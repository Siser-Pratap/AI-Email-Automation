// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
  engineType      = "library"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model EmailEntry {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  hrEmail     String
  companyName String?
  role        String
  emailType   String    // "REFERRAL", "APPLICATION", "INTEREST", "FOLLOWUP"
  name        String?   // Recipient Name
  jobId       String?   // Job ID for referrals
  status      String    @default("PENDING") // "PENDING", "SENT", "FAILED"
  scheduledAt DateTime  @default(now())
  lastSentAt  DateTime?
  retryCount  Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  logs EmailLog[]
}

model EmailTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String   @unique // "REFERRAL", "APPLICATION", "INTEREST", "FOLLOWUP"
  subject   String
  body      String   // supports variables like {{company}}, {{role}}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  emailEntryId String     @db.ObjectId
  status       String     // "SUCCESS", "FAILURE"
  response     String?
  timestamp    DateTime   @default(now())

  emailEntry EmailEntry @relation(fields: [emailEntryId], references: [id], onDelete: Cascade)
}
